# Execution State
state: "eval"  # train, eval, or select_best
device: "cuda:0"
seed: 1

# Dataset Configuration
data_keys:
  data: "data" # Change if your .mat uses 'img', 'cube', etc.
  map: "map"   # Change if your .mat uses 'gt', 'label', etc.

# Model Architecture
model:
  band: 189
  group_length: 20
  depth: 4
  heads: 4
  dim_head: 64
  mlp_dim: 64
  channel: 128
  adjust: false

# Hyperparameters
training:
  epoch: 20
  batch_size: 64
  lr: 1.0e-4
  multiplier: 2
  epision: 5
  grad_clip: 1.0
  save_freq: 1  # Save model every m epochs

# Paths and Checkpoints
paths:
  save_dir: "./Checkpoint/"
  run_name: "experiment_1" # Added to clean up checkpoint saving
  dataset_path: "/Users/mac/Desktop/school/MSC/LAB/hyspan_lib/datasets/real/Sandiego.mat"
  training_load_weight: null
  test_load_weight: "ckpt_5_.pt"